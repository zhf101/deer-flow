#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

export UV_CACHE_DIR="${UV_CACHE_DIR:-$REPO_ROOT/.uv-cache}"
mkdir -p "$UV_CACHE_DIR"

if command -v python >/dev/null 2>&1; then
  PYTHON=(python)
elif command -v py >/dev/null 2>&1; then
  PYTHON=(py -3)
else
  echo "Python is required to run staged text checks." >&2
  exit 1
fi

if ! command -v uv >/dev/null 2>&1; then
  echo "uv is required for backend linting." >&2
  exit 1
fi

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is required for frontend linting." >&2
  exit 1
fi

echo "[pre-commit] Checking staged text files"
"${PYTHON[@]}" scripts/check_staged_text.py

echo "[pre-commit] Running backend Ruff"
(
  cd backend
  uv run --no-sync ruff check .
)

echo "[pre-commit] Running frontend lint"
pnpm --dir frontend lint
