{
  "name": "gdpui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vsext": "vite --mode vsext",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "cross-env NODE_OPTIONS=\"--max_old_space_size=8192 --unhandled-rejections=strict\" vite build",
    "build-only:vsext": "cross-env NODE_OPTIONS=\"--max_old_space_size=8192 --unhandled-rejections=strict\" vite --mode vsext build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^2.0.10",
    "@tailwindcss/vite": "^4.1.11",
    "@tinymce/tinymce-vue": "3.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "axios": "^1.17.0",
    "element-ui": "2.15.14",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "markdown-it-highlightjs": "^4.2.0",
    "marked": "13.0.3",
    "md5": "^2.3.0",
    "mermaid": "11.6.0",
    "pinia": "2",
    "pinia-plugin-persistedstate": "3.2.3",
    "sass": "^1.78.0",
    "sass-loader": "^13.3.2",
    "sm-crypto": "^0.4.0",
    "tailwindcss": "^4.1.11",
    "tinymce": "5.8.2",
    "uuid": "^11.1.0",
    "vite-plugin-vscode-webview-hmr": "^1.0.1",
    "vue": "^2.7.16",
    "vue-animated-list": "^1.0.2",
    "vue-router": "^3.6.5",
    "vue-template-compiler": "^2.7.16",
    "vue-tsc": "^3.3.4"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.1",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-legacy": "^6.1.1",
    "@vitejs/plugin-vue2": "^2.3.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.22.0",
    "eslint-plugin-oxlint": "^0.16.0",
    "eslint-plugin-vue": "^10.0.0",
    "jiti": "^2.4.2",
    "jsdom": "^26.0.0",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^0.16.0",
    "prettier": "3.5.3",
    "sass-embedded": "1.97.0",
    "terser": "^5.42.0",
    "typescript": "^5.8.0",
    "vite": "^6.2.4",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vitest": "^3.1.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "Firefox ESR",
    "not dead",
    "chrome > 70",
    "ie 11"
  ]
}
